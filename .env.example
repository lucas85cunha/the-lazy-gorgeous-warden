# --- Google AI Studio Configuration ---
# Get your API Key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# --- Warden Project Settings ---
# Absolute path to the directory you want to audit/organize
# Example for Linux: /run/media/user/external_hd
TARGET_DIRECTORY=your_path_directory

# Execution Mode
# Set to True to only simulate changes (recommended for safety)
# Set to False to allow the Warden to move/rename files
DRY_RUN=True

# Log Level
# Options: INFO, DEBUG, WARNING
LOG_LEVEL=INFO
